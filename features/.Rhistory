library(lme4)
library(tidyverse)
setwd("~/Documents/MATLAB/affect_detection/features")
# Create list of files
files_list <- list.files()
# Concatenate all files
all_files <- list()
for (file in 1:length(files_list)) {
file_data <- read.csv(files_list[file])
all_files <- bind_rows(all_files, file_data)
}
# Build full model
full.model = lmer(frontal_asymmetry ~ negativity_rating + positivity_rating + net_predisposition_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+negativity_rating|second) +
(1+negativity_rating|band),
REML=FALSE,
data = all_files,
control = lmerControl(calc.derivs = FALSE))
# Build null model
reduced.model = lmer(frontal_asymmetry ~ positivity_rating + net_predisposition_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+negativity_rating|second) +
(1+negativity_rating|band),
REML=FALSE,
data = all_files,
control = lmerControl(calc.derivs = FALSE))
# Obtain likelihood ratio for negativity dimension
result <- anova(reduced.model, full.model)
print(result)
