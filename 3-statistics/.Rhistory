# Define power bands
bands <- list('delta', 'theta', 'alpha', 'beta', 'gamma')
# Dataset collected during pilot experiment in VR
exp_data <- read.csv("../features/pilot_exp_features.csv")
# Define linear mixed models function
exp_lmm <- function(exp_data) {
# Create empty vector to store results from each power band
bands_results <- vector()
for (b in bands) {
# Subset data from current power band
band_data <- exp_data %>%
filter(band == b)
# Build full model
band.model = lmer(frontal_asymmetry ~ negativity_rating + positivity_rating + net_repdisposition_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+positivity_rating|participant) +
(1+positivity_rating|video_id) +
(1+net_repdisposition_rating|participant) +
(1+net_repdisposition_rating|video_id),
data=exp_data,
REML=FALSE)
# Build reduced model without negativity ratings
band.null_negativity = lmer(frontal_asymmetry ~ positivity_rating + net_repdisposition_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+positivity_rating|participant) +
(1+positivity_rating|video_id) +
(1+net_repdisposition_rating|participant) +
(1+net_repdisposition_rating|video_id),
data=exp_data,
REML=FALSE)
# Build reduced model without positivity ratings
band.null_negativity = lmer(frontal_asymmetry ~ negativity_rating + net_repdisposition_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+positivity_rating|participant) +
(1+positivity_rating|video_id) +
(1+net_repdisposition_rating|participant) +
(1+net_repdisposition_rating|video_id),
data=exp_data,
REML=FALSE)
# Build reduced model without net predisposition ratings
band.null_negativity = lmer(frontal_asymmetry ~ negativity_rating + positivity_rating +
(1+negativity_rating|participant) +
(1+negativity_rating|video_id) +
(1+positivity_rating|participant) +
(1+positivity_rating|video_id) +
(1+net_repdisposition_rating|participant) +
(1+net_repdisposition_rating|video_id),
data=exp_data,
REML=FALSE)
# Obtain likelihood ratio for negativity dimension
result_negativity <- anova(band.null_negativity,band.model)
# Obtain likelihood ratio for positivity dimension
result_positivity <- anova(band.null_positivity,band.model)
# Obtain likelihood ratio for net predisposition dimension
result_net_predisposition <- anova(band.null_net_predisposition,band.model)
# Store results from each dimension in a list
dimensions_results <- list()
dimensions_results[[sprintf('%s_negativity', b)]] <- result_negativity
dimensions_results[[sprintf('%s_positivity', b)]] <- result_positivity
dimensions_results[[sprintf('%s_net_predisposition', b)]] <- result_net_predisposition
# Append results from both dimensions to another list, creating a nested list
bands_results <- append(bands_results, dimensions_results)
}
return(bands_results)
}
